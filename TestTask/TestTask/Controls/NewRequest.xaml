<UserControl x:Class="TestTask.Controls.NewRequest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TestTask.Controls"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="1" Content="Новый запрос" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
        <Label Grid.Row="1" Grid.Column="1" Content="Вид справки" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Bottom"  Margin="0,5"/>
        <ComboBox x:Name="RequestTypeComboBox" Grid.Row="2" Grid.Column="1" Margin="0,5" HorizontalAlignment="Left" VerticalAlignment="Center" Width="250" Height="50"/>
        <Label Grid.Row="3" Grid.Column="1" Content="Количество экземпляров" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5"/>
        <TextBox x:Name="RequestsNumberTextBox" Grid.Row="4" Grid.Column="1" Height="50" FontSize="16"/>
        <Label Grid.Row="5" Grid.Column="1" Content="Причина" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5"/>
        <RichTextBox x:Name="RequestReasonTextBox" Grid.Row="6" Grid.Column="1" Margin="0,5" HorizontalAlignment="Left" VerticalAlignment="Top" Width="400" Height="100" FontSize="16"/>
        <Grid Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2">
            <Button x:Name="Send" Content="Отправить" Background="AliceBlue" HorizontalAlignment="Right" Margin="150,5" Width="150" Height="40" PreviewMouseLeftButtonDown="Send_PreviewMouseLeftButtonDown"/>
            <Button x:Name="Cancel" Content="Отменить" HorizontalAlignment="Right" Margin="10,5" Width="100" Height="40" PreviewMouseLeftButtonDown="Cancel_PreviewMouseLeftButtonDown"/>         
        </Grid>
    </Grid>
</UserControl>
